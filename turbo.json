{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "AUTH_SECRET",
    "AUTH_URL",
    "NEXT_PUBLIC_APP_URL",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "GITHUB_TOKEN",
    "GITHUB_OWNER",
    "GITHUB_REPO",
    "QDRANT_URL",
    "QDRANT_API_KEY",
    "QDRANT_VECTOR_SIZE",
    "QDRANT_SCORE_THRESHOLD",
    "QDRANT_CHECK_COMPATIBILITY",
    "AI_PROVIDER",
    "OPENAI_API_KEY",
    "OPENAI_CHAT_MODEL",
    "OPENAI_EMBEDDING_MODEL",
    "ANTHROPIC_API_KEY",
    "GEMINI_API_KEY",
    "GEMINI_CHAT_MODEL",
    "GEMINI_CHAT_FALLBACK_MODELS",
    "GEMINI_EMBEDDING_MODEL",
    "INDEXER_POLL_MS",
    "REDIS_URL",
    "DISABLE_AUTH",
    "DEV_AUTH_USER_EMAIL",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
