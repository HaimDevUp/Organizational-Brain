# Database
DATABASE_URL="postgresql://obos:obos@localhost:5432/obos?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Dev only — skip login & RBAC (ignored when NODE_ENV=production)
DISABLE_AUTH="false"
DEV_AUTH_USER_EMAIL="dev@obos.local"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub (knowledge repos)
GITHUB_TOKEN=""
GITHUB_OWNER=""
GITHUB_REPO=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Qdrant
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
# Set QDRANT_CHECK_COMPATIBILITY=true in prod when client/server versions are pinned
QDRANT_VECTOR_SIZE="1536"
# Use 3072 when AI_PROVIDER=gemini and GEMINI_EMBEDDING_MODEL=gemini-embedding-001
QDRANT_SCORE_THRESHOLD="0.55"

# AI (default: openai). For Gemini-only: AI_PROVIDER=gemini + GEMINI_API_KEY + QDRANT_VECTOR_SIZE=3072
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
# List models: GET https://generativelanguage.googleapis.com/v1beta/models?key=...
# gemini-1.5-flash is deprecated/removed; gemini-2.0-flash may hit free-tier quota (429)
GEMINI_CHAT_MODEL="gemini-2.0-flash"
GEMINI_CHAT_FALLBACK_MODELS="gemini-2.5-flash,gemini-flash-latest"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Indexer worker
INDEXER_POLL_MS="5000"

# Knowledge graph (Phase 5)
GRAPH_EXPANSION_DEPTH="2"
GRAPH_MAX_DOCUMENTS="15"
GRAPH_SEMANTIC_TOP_K="3"

# Redis (optional — distributed rate limits in production)
REDIS_URL="redis://localhost:6379"

# Observability (optional)
SENTRY_DSN=""
LOG_LEVEL="info"
